  "sourceName": "ModularAPITemplate",
  "preferNameDirectory": true,
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**",
            "templates/**",
            ".git/**",
            "**/.vs/**",
            "**/*.user",
            ".copilot/.tasks/**"
          ]
        }
      ]
    }
  ]
}
