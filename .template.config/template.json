{
  "$schema": "http://json.schemastore.org/template",
  "author": "Lasthy",
  "classifications": [
    "Web",
    "API",
    "Modular",
    "Clean Architecture"
  ],
  "identity": "ModularAPITemplate.Solution",
  "name": "Modular API Template",
  "shortName": "modularapi",
  "description": "Template para criação de Web APIs modulares em .NET com Clean Architecture, EF Core, MediatR e eventos de integração.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory": true,
  "sourceName": "ModularAPITemplate",
  "symbols": {
    "sanitizedName": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "replaceDashWithDot",
      "replaces": "ModularAPITemplate",
      "fileRename": "ModularAPITemplate"
    }
  },
  "forms": {
    "replaceDashWithDot": {
      "identifier": "replace",
      "pattern": "-",
      "replacement": "."
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**",
            "templates/**",
            ".git/**",
			      "LICENSE.txt",
            "README.md",
            "**/.vs/**",
            "**/*.user",
            ".copilot/.tasks/**"
          ]
        }
      ]
    }
  ]
}
