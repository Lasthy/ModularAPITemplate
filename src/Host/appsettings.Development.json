{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Modules": {
    "Example": {
      "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=ExampleModule;Trusted_Connection=True;MultipleActiveResultSets=true",
      "Outbox": {
        "Enabled": true,
        "IntervalMilliseconds": 1000,
        "BatchSize": 50,
        "PartitionCount": 64,
        "PartitionStart": 0,
        "PartitionEnd": 63,
        "RecoveryThresholdSeconds": 300,
        "CleanupThresholdDays": 21
      }
    }
  }
}
